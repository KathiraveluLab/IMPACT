# k8s/secret.yaml.example  <-- RENAME to secret.yaml locally; never commit secret.yaml
#
# To create the secret without a file:
#   kubectl create secret generic postgres-secret \
#     --from-literal=username=<your-db-user> \
#     --from-literal=password=<your-db-password> \
#     -n impact-crawler
#
# If you prefer a file, copy this to secret.yaml, fill in real base64 values:
#   echo -n 'myuser' | base64
#   echo -n 'mypassword' | base64
# Then: kubectl apply -f k8s/secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: impact-crawler
type: Opaque
data:
  username: REPLACE_WITH_BASE64_USERNAME
  password: REPLACE_WITH_BASE64_PASSWORD
