.agent
.gemini

# Python compiled files
.venv/
__pycache__/
*.py[cod]
*$py.class

# Ignore all crawled benchmark repository folders by default to prevent committing large files
test_projects/github_benchmarks/*/*/

# Whitelist only the small benchmark test baselines
!test_projects/github_benchmarks/java/google_gson/
!test_projects/github_benchmarks/java/iluwatar_java-design-patterns/
!test_projects/github_benchmarks/java/jhy_jsoup/
!test_projects/github_benchmarks/java/krahets_hello-algo/
!test_projects/github_benchmarks/java/macrozheng_mall/
!test_projects/github_benchmarks/java/reactive-streams_reactive-streams-jvm/
!test_projects/github_benchmarks/java/square_javapoet/

# Ignore extracted GitHub source folders in the whitelisted benchmarks
test_projects/github_benchmarks/*/*/*/

# Python packaging build artifacts — never commit
build/
dist/
*.egg-info/
# Copy k8s/secret.yaml.example -> k8s/secret.yaml and fill in values locally
k8s/secret.yaml

# SQLite databases and sidecar files
*.db
*.db-journal
*.db-wal
*.db-shm

# Dynamic runtime configuration for the dashboard
core/dashboard/config.js
core/dashboard/test_projects/
.env

# Exported CSVs and spreadsheet viewer lockfiles
*.csv
.~lock.*.csv#